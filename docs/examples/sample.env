# Sample environment file for KosXER
# This demonstrates various key-value formats

# ============================================
# Application Configuration
# ============================================

# Database settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp
DB_USER=appuser
DB_PASS="secure_password_123"

# Redis cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ============================================
# API Keys (example - don't use real keys here)
# ============================================

# API configuration
API_BASE_URL=https://api.example.com
API_VERSION=v1
API_TIMEOUT=30

# ============================================
# Feature Flags
# ============================================

# Enable features
FEATURE_NEW_UI=true
FEATURE_BETA_MODE=false
FEATURE_DARK_MODE=yes

# ============================================
# Paths
# ============================================

# Application paths
APP_DATA_PATH=/var/lib/myapp
APP_LOG_PATH=/var/log/myapp
APP_TEMP_PATH=/tmp/myapp

# With spaces (quoted)
APP_DESCRIPTION="My Application Description"
APP_WELCOME_MESSAGE="Welcome to the application!"

# ============================================
# Export Examples (for shell sourcing)
# ============================================

# These would be sourced with: source .env
export PATH="/usr/local/bin:$PATH"
export EDITOR=vim
export VISUAL=code

# ============================================
# Special Characters
# ============================================

# Escaped characters
SPECIAL_TAB="value\twith\ttabs"
SPECIAL_NEWLINE="line1\nline2"
SPECIAL_QUOTE="He said \"Hello\""

# URLs
DATABASE_URL="postgresql://user:pass@localhost:5432/db"
REDIS_URL="redis://localhost:6379/0"

# ============================================
# Comments and Notes
# ============================================

# This is a comment
KEY=value  # This is an inline comment

# Empty values are allowed
EMPTY_VALUE=

# Boolean variations
BOOL_TRUE_1=true
BOOL_TRUE_2=yes
BOOL_TRUE_3=1
BOOL_TRUE_4=on

BOOL_FALSE_1=false
BOOL_FALSE_2=no
BOOL_FALSE_3=0
BOOL_FALSE_4=off
